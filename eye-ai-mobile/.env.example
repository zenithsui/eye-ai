# Copy to .env (untracked) for local Expo development.
# Expo automatically loads EXPO_PUBLIC_* vars at build/bundle time.
# These are NOT for Vercel — this is a separate Expo/React Native app.

EXPO_PUBLIC_GROQ_KEY=
EXPO_PUBLIC_OPENROUTER_KEY=
EXPO_PUBLIC_MISTRAL_KEY=
EXPO_PUBLIC_CEREBRAS_KEY=
EXPO_PUBLIC_GEMINI_KEY=
EXPO_PUBLIC_ELEVENLABS_KEY=
EXPO_PUBLIC_TAVILY_KEY=
